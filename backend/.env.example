# ============================================
# SECURITY: NEVER commit .env to version control
# This is a template file - copy to .env and fill with real values
# ============================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
# Example: mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority
MONGO_URI=

# JWT signing secret
JWT_SECRET=

# Google OAuth web client ID
GOOGLE_CLIENT_ID=

# Optional: frontend origin for stricter CORS setup
# CLIENT_URL=http://localhost:5173

# Optional: comma-separated origins for API + Socket CORS allowlist
# ALLOWED_ORIGINS=https://your-frontend.onrender.com,http://localhost:5173
