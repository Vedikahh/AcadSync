# Backend API URL (default: http://localhost:5000)
VITE_API_URL=http://localhost:5000

# Google OAuth web client ID
VITE_GOOGLE_CLIENT_ID=your_google_client_id

# Optional: frontend AI conflict assist messaging toggle (true/false).
# Even when true, backend availability determines whether AI assist is active.
# VITE_ENABLE_AI_CONFLICT_ASSIST=false

# Frontend env files must only contain VITE_ prefixed public values.
# Never place server secrets (JWT_SECRET, MONGO_URI, GEMINI_API_KEY, etc.) in frontend env files.
